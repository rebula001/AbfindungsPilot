  "scripts": {
    "dev": "vite",
    "build": "npm run check:all && vue-tsc -b && vite build",
    "build:fast": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "check:all": "npm run lint:check && npm run format:check && npm run i18n:check",
    "format:check": "prettier . --check",
    "format:fix": "prettier . --write",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "sonar:all": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sonar-scan.ps1",
    "i18n:check": "node scripts/check-i18n-keys.mjs",
    "pack": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pack-frontend.ps1"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "@primevue/forms": "^4.5.5",
    "chart.js": "^4.5.1",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "vue": "^3.5.33",
    "vue-i18n": "^11.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-vue": "^6.0.6",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "tailwindcss-primeui": "^0.6.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.7"
  }
